{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kern",
  "version": "0.2.0",
  "identifier": "com.ellio.kern",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-nsis.mjs && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "kern",
        "width": 1100,
        "height": 740,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://*, manifest-src 'self' asset:; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCAL/**", "$DOCUMENT/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["kern"],
        "name": "kern Plugin Package",
        "description": "kern plugin package file"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "template": "./windows/nsis-skin/installer.nsi",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "deepLink": {
      "desktop": {
        "schemes": ["kern"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/ellipog/kern/releases/latest/download/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxMUI3RDY5RjQwN0QzRjcKUldUMzB3ZjBhWDBiZ1JnZnVXRWk3OW12RnAyYnBlQmJJM0pVMVhaOGF1Yjl5VUtGL213bFg1OU4K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
