{
  "name": "kern-video",
  "version": "1.0.0",
  "private": true,
  "description": "kern promo video — Remotion compositions and render pipeline. Standalone; intentionally not part of the Tauri app.",
  "scripts": {
    "dev": "remotion studio",
    "studio": "remotion studio",
    "render": "remotion render KernVideo out/kern-promo.mp4 && remotion render HeroLoop out/kern-hero-loop.mp4",
    "render:promo": "remotion render KernVideo out/kern-promo.mp4",
    "render:loop": "remotion render HeroLoop out/kern-hero-loop.mp4",
    "render:node": "bun run scripts/render.ts",
    "sfx": "bun run scripts/gen-sfx.ts",
    "music": "bun run scripts/gen-music.ts",
    "audio": "bun run music && bun run sfx",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.496",
    "@remotion/cli": "4.0.496",
    "@remotion/google-fonts": "4.0.496",
    "@remotion/renderer": "4.0.496",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.496"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "typescript": "5.8.3"
  }
}
